# Node identity
NODE_NAME=jupyter-node
NODE_TYPE=jupyter
NODE_PORT=8002

# JupyterLab UI port (separate from the FastAPI node port)
JUPYTER_LAB_PORT=8888

# Direct sibling URLs — set by orchestrator Makefile, not hardcoded
# Used by SiblingClient for direct HTTP calls (no A2A overhead)
SIBLING_MODEL_NODE_URL=http://model-node:8001

# Orchestrator URL resolution — two-variable fallback chain:
#
#   ORCHESTRATOR_URL        Set this when you need a hard override (container kernel,
#                           custom deploy). Takes priority over everything else.
#
#   ORCHESTRATOR_PUBLIC_URL Set this when running a LOCAL kernel outside the docker
#                           bridge network (e.g. `jupyter lab` on the host machine).
#                           The notebooks use this as a fallback when ORCHESTRATOR_URL
#                           is not set, so you never need to remember to rename vars.
#
#   (neither set)           Falls back to http://orchestrator:8000 — only works
#                           inside the compose docker bridge (container kernels).
#
# For local development with `make up` on Linux/WSL:
# ORCHESTRATOR_PUBLIC_URL=http://localhost:8000
#
# For a deployed instance (replace with your actual ingress URL):
# ORCHESTRATOR_PUBLIC_URL=https://your-orchestrator.example.com
ORCHESTRATOR_URL=http://localhost:8000

# Publish secret — must match PUBLISH_SECRET set on the orchestrator in production.
# Leave unset in development (check is skipped when NODE_ENV != production).
# PUBLISH_SECRET=change-me-in-production

# Optional: Postgres for data access from kernel namespaces
# POSTGRES_DSN=postgresql://user:pass@postgres:5432/labmarket
